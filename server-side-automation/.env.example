# Uniteus Login Credentials (REQUIRED)
UNITEUS_EMAIL=your-email@example.com
UNITEUS_PASSWORD=your-password

# Server Configuration (OPTIONAL - defaults shown)
PORT=3500

# Browser Configuration (OPTIONAL)
# Set to 'true' to run browser in headless mode (no visible window)
HEADLESS=false

# API Configuration (if used)
# EXTENSION_API_BASE_URL=https://your-api.vercel.app
# EXTENSION_API_KEY=your-api-key

# Device authorization: only these device IDs can run automation.
# GET this URL must return JSON: {"deviceIds":["ABC123","DEF456"]}
# If unset, no device check is applied (all devices allowed).
# AUTHORIZED_DEVICES_URL=https://your-api.example.com/allowed-devices

# Number of parallel browser instances (always this many; no CPU-based scaling)
# MAX_BROWSERS=15
